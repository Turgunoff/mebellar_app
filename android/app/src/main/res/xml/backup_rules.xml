<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android 12 (API 23–30) Auto Backup rules.
    Mirrors the data_extraction_rules.xml exclusions for older devices.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="FlutterSecureStorage" />
    <exclude domain="database" />
    <exclude domain="file" path="hive" />
</full-backup-content>

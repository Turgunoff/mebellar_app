**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase Admin SDK service-account JSONs — contain a private key that
# can mint OAuth2 tokens against the Firebase project. Never commit.
# woody-*-firebase-adminsdk-*.json
# *-firebase-adminsdk-*.json
# serviceAccountKey.json

# # Environment / secrets — every env file is ignored except the committed
# # template. dev.json / prod.json were un-tracked via `git rm --cached`;
# # real keys now live only in untracked env files (see env/example.json).
# /env/dev.json
# /env/prod.json
# /env/*.json
# !env/example.json
